class List(tk.Toplevel):
    def __init__(self, root):
        super().__init__(root)
        self.title("Боковая панель")
        self.configure(bg=BEIGE)

        screen_width = self.winfo_screenwidth()
        screen_height = self.winfo_screenheight()

        percent_width = 0.15
        percent_height = 0.55

        window_width = int(screen_width * percent_width)
        window_height = int(screen_height * percent_height)

        root.update_idletasks()
        main_x = root.winfo_x()
        main_y = root.winfo_y()

        offset = 10
        x = main_x - window_width - offset
        y = main_y

        if x < 0:
            x = offset

        self.geometry(f"{window_width}x{window_height}+{x}+{y}")

        tk.Label(self, text="Выберите аудио:").pack(pady=10)

        ctk.CTkButton(self, text="1 СЛОЖНОСТЬ", command=lambda c=Main1: self.replace_main(root, c)).pack(anchor="w")
        ctk.CTkButton(self, text="2 СЛОЖНОСТЬ", command=lambda c=Main2: self.replace_main(root, c)).pack(anchor="w")
        ctk.CTkButton(self, text="3 СЛОЖНОСТЬ", command=lambda c=Main3: self.replace_main(root, c)).pack(anchor="w")
        ctk.CTkButton(self, text="4 СЛОЖНОСТЬ", command=lambda c=Main4: self.replace_main(root, c)).pack(anchor="w")

    def replace_main(self, root, new_main_class):
        try:
            if self.winfo_exists():
                self.destroy()
        except Exception:
            pass
        try:
            root.destroy()
        except Exception:
            pass
        new_app = new_main_class()
        new_app.mainloop()


